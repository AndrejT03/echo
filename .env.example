# ЕХО — environment променливи
#
# Апликацијата работи и БЕЗ овој клуч: ако нема клуч, емоционалната
# анализа се пресметува локално (heuristic на македонски). Со клуч,
# анализата ја прави Google Gemini и е значително попрецизна.

# Google Gemini API клуч — земи од https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Модел (опционо). Default: gemini-3.1-flash-lite
GEMINI_MODEL=gemini-3.1-flash-lite
